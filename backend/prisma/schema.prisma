model Course {
  id        String @id @default(uuid())
  name      String
  duration  String

  collegeId String

  college College
    @relation(
      fields:[collegeId],
      references:[id]
    )
}

model Review {
  id        String @id @default(uuid())

  title     String

  comment   String

  rating    Float

  collegeId String

  college College
    @relation(
      fields:[collegeId],
      references:[id]
    )
}