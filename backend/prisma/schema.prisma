generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id              String   @id @default(uuid())
  name            String
  location        String?
  type            String   @default("Engineering")
  imageUrl        String?

  fees            Int      @default(0)
  rating          Float    @default(0)
  overview        String?
  established     Int?

  averagePackage  Int      @default(0)
  highestPackage  Int      @default(0)

  courses         Course[]
  students        Student[]
  reviews         Review[]
  savedBy         SavedCollege[]
}

model Course {
  id        String  @id @default(uuid())
  name      String
  duration  String

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])
}

model Student {
  id        String  @id @default(uuid())
  name      String

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])
}

model Review {
  id        String  @id @default(uuid())
  title     String
  comment   String
  rating    Float

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  saved     SavedCollege[]
  createdAt DateTime @default(now())
}

model SavedCollege {
  id        String   @id @default(uuid())
  userId    String
  collegeId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}
